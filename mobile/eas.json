{
  "cli": {
    "version": ">= 18.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "dev": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_BASE_URL": "REPLACE_WITH_DEV_API_URL"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_BASE_URL": "REPLACE_WITH_PROD_API_URL"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
